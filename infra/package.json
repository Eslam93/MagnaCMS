{
  "name": "magnacms-infra",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK app for MagnaCMS infrastructure (TypeScript)",
  "bin": {
    "magnacms": "bin/magnacms.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth": "cdk synth --all -c env=dev",
    "synth:diff": "cdk diff --all -c env=dev",
    "lint": "echo 'CDK lint TBD — relies on tsc + jest snapshots for now'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.180.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "engines": {
    "node": ">=20"
  }
}
