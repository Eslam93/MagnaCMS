# ──────────────────────────────────────────────────────────────────────
# MagnaCMS — environment template.
# Copy this to `.env` and fill in OPENAI_API_KEY + JWT_SECRET.
# Everything else has a sane local default.
#
# In production, all secrets live in AWS Secrets Manager; non-secret config
# is set via App Runner's plain environment configuration.
# ──────────────────────────────────────────────────────────────────────

# --- AI provider mode ---
# openai (primary) | bedrock | mock
AI_PROVIDER_MODE=openai

# --- OpenAI (primary provider) ---
# Get a key at https://platform.openai.com/api-keys. Set a hard usage cap
# (we recommend $25/month) at https://platform.openai.com/account/limits
# to prevent runaway loops in dev.
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_TEXT_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=medium     # low | medium | high
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=3

# --- AWS (only required for hosting and S3; not needed for local dev) ---
AWS_REGION=us-east-1
# Local dev: leave blank and configure via `aws configure` / SSO if you want
# to test S3 uploads. App Runner uses an IAM role — no keys in env in prod.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Database (Postgres) ---
# Docker-compose service name `postgres` resolves from the backend container.
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app
# Compose-only overrides (the postgres image reads these on first boot):
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# --- Redis ---
USE_REDIS=true
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_with_openssl_rand_hex_32
JWT_ACCESS_TOKEN_TTL_SECONDS=900       # 15 minutes
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000  # 30 days

# --- Storage ---
S3_BUCKET_IMAGES=ai-content-images-dev
# Local dev fallback: backend serves images from disk via this path prefix.
# Production: https://images.<your-domain>
IMAGES_CDN_BASE_URL=http://localhost:8000/local-images

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Sentry DSN exposed to the browser bundle. Leave blank in dev; the
# frontend's @sentry/nextjs init silently no-ops when this is empty.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=dev

# --- Observability ---
# Backend Sentry DSN. Same silent-no-op rule — leave blank in dev.
SENTRY_DSN=
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────
# Alternative AI providers (documented only — not active code paths).
# Set AI_PROVIDER_MODE=bedrock to use these instead of OpenAI.
#
# Claude Sonnet 4.5 on Bedrock requires:
#   1. Use the US cross-region inference profile (NOT the bare model ID)
#   2. Submit the "Anthropic use case details" form in the Bedrock console
#   3. Enable model access at:
#      https://us-east-1.console.aws.amazon.com/bedrock/home#/modelaccess
#
# Nova Canvas is `LEGACY` — EOL 2026-09-30. Migrate before then.
# ──────────────────────────────────────────────────────────────────────
BEDROCK_TEXT_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_IMAGE_MODEL_ID=amazon.nova-canvas-v1:0
